# ============================================================
# Lion Cub — Variables de entorno para automatización n8n
# Copia este archivo como .env en tu instancia de n8n y
# rellena los valores. NUNCA subas este archivo con valores reales.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# URL pública del proyecto (visible en Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Service-role key (Settings > API > service_role secret)
# Tiene acceso completo y bypasea RLS. MANTENER SECRETO.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon key (solo para operaciones públicas, opcional en n8n)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API de la app Lion Cub ───────────────────────────────────
# URL base de la app desplegada en Vercel (sin barra final)
LIONCUB_APP_URL=https://lioncub.pe

# Token de sesión de admin para llamar a /api/asset/render
# Obtenerlo iniciando sesión en el panel admin y copiando el access_token de Supabase
# (supabase.auth.getSession().data.session.access_token)
LIONCUB_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (generación de ideas con IA) ──────────────────
# API key de Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelo a usar para generación de ideas (recomendado: claude-haiku-4-5-20251001 por costo)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Meta / Instagram Graph API ──────────────────────────────
# App ID y App Secret de tu Meta App (developers.facebook.com)
META_APP_ID=1234567890123456
META_APP_SECRET=abcdef1234567890abcdef1234567890

# Page Access Token con permisos: instagram_basic, instagram_content_publish,
# instagram_manage_insights, pages_read_engagement
# Genera en Graph API Explorer o via /oauth/access_token con long-lived token
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxx

# ID numérico de tu cuenta de Instagram Business (no el username)
# GET https://graph.facebook.com/v21.0/me/accounts → data[0].instagram_business_account.id
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841400000000000

# ── TikTok Content Posting API ──────────────────────────────
# Client Key y Client Secret de tu TikTok Developer App (developers.tiktok.com)
TIKTOK_CLIENT_KEY=awxxxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access Token con scope: video.upload, video.publish
# Obtenido via OAuth 2.0 PKCE flow de TikTok
TIKTOK_ACCESS_TOKEN=act.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Open ID del creator autenticado (retornado en el OAuth callback)
TIKTOK_OPEN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── YouTube Data API v3 ─────────────────────────────────────
# Credenciales OAuth 2.0 de Google Cloud Console (console.cloud.google.com)
# Habilitar: YouTube Data API v3
YOUTUBE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# Refresh token OAuth obtenido via Google OAuth 2.0 Playground
# Scope: https://www.googleapis.com/auth/youtube.upload
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Canal / Channel ID de YouTube (UCxxxxxxxxxxxxxxxxxx)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n configuración interna ───────────────────────────────
# URL base de tu instancia de n8n (solo si usas la API de importación)
N8N_API_URL=https://n8n.tudominio.com
N8N_API_KEY=n8n_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Opcionales / Futuros ────────────────────────────────────
# Webhook URL de n8n para disparar el workflow desde el panel admin
N8N_WEBHOOK_CONTENT_MILL=https://n8n.tudominio.com/webhook/content-mill-lioncub
