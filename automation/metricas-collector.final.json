      ]
    },
    "¿Qué red?": {
      "main": [
        [{ "node": "Instagram — Insights", "type": "main", "index": 0 }],
        [{ "node": "TikTok — Métricas", "type": "main", "index": 0 }],
        [{ "node": "Facebook — Insights", "type": "main", "index": 0 }]
      ]
    },
    "Instagram — Insights": {
      "main": [
        [{ "node": "Normalizar IG", "type": "main", "index": 0 }]
      ]
    },
    "Normalizar IG": {
