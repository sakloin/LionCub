        [{ "node": "Unir Métricas", "type": "main", "index": 0 }]
      ]
    },
    "TikTok — Métricas": {
      "main": [
        [{ "node": "Normalizar TikTok", "type": "main", "index": 0 }]
      ]
    },
    "Normalizar TikTok": {
      "main": [
        [{ "node": "Unir Métricas", "type": "main", "index": 1 }]
      ]
    },
    "Facebook — Insights": {
      "main": [
        [{ "node": "Normalizar Facebook", "type": "main", "index": 0 }]
      ]
    },
    "Normalizar Facebook": {
      "main": [
        [{ "node": "Unir Métricas", "type": "main", "index": 2 }]
      ]
    },
    "Unir Métricas": {
      "main": [
        [{ "node": "Guardar en Supabase", "type": "main", "index": 0 }]
      ]
    },
    "Guardar en Supabase": {
      "main": [
        [{ "node": "Siguiente Post", "type": "main", "index": 0 }]
      ]
    },
    "Siguiente Post": {
